<?xml version="1.0" encoding="utf-8"?>
<!--
    include_home_stats.xml
    Dos tarjetas de estadísticas en fila: Resueltos | Comunidad.
    Uso de LinearLayout con layout_weight para igualar anchos.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:weightSum="2">

    <!-- Tarjeta: Resueltos -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/space_sm"
        app:cardBackgroundColor="@color/surface_white"
        app:cardCornerRadius="@dimen/card_radius_md"
        app:cardElevation="@dimen/card_elevation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_marginBottom="@dimen/space_xs"
                android:contentDescription="@null"
                android:src="@drawable/ic_check_circle_outline"
                app:tint="@color/blue_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_resueltos"
                android:textAppearance="@style/TextAppearance.CivicHero.StatLabel" />

            <TextView
                android:id="@+id/tvStatResueltos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_resueltos"
                android:textAppearance="@style/TextAppearance.CivicHero.StatValue" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Tarjeta: Comunidad -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/space_sm"
        app:cardBackgroundColor="@color/surface_white"
        app:cardCornerRadius="@dimen/card_radius_md"
        app:cardElevation="@dimen/card_elevation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <ImageView
                android:layout_width="@dimen/icon_md"
                android:layout_height="@dimen/icon_md"
                android:layout_marginBottom="@dimen/space_xs"
                android:contentDescription="@null"
                android:src="@drawable/ic_chat_outline"
                app:tint="@color/amber_600" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_comunidad"
                android:textAppearance="@style/TextAppearance.CivicHero.StatLabel" />

            <TextView
                android:id="@+id/tvStatComunidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_comunidad"
                android:textAppearance="@style/TextAppearance.CivicHero.StatValue" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
