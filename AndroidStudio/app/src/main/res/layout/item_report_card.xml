<?xml version="1.0" encoding="utf-8"?>
<!--
    item_report_card.xml
    Item individual del RecyclerView de reportes recientes.
    Inflado por RecentReportsAdapter.
    Estructura: imagen | info (título, meta, chip apoyos) | badge estado
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_sm"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/surface_white"
    app:cardCornerRadius="@dimen/card_radius_md"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <!-- Miniatura del reporte -->
        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/report_thumb_size"
            android:layout_height="@dimen/report_thumb_size"
            android:layout_marginEnd="@dimen/space_md"
            app:cardCornerRadius="@dimen/card_radius_sm"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgReportThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_report_image"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_image_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- Bloque de información central -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Título del reporte -->
            <TextView
                android:id="@+id/tvReportTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/sample_report_title"
                android:textAppearance="@style/TextAppearance.CivicHero.ReportTitle" />

            <!-- Meta: tiempo · lugar -->
            <TextView
                android:id="@+id/tvReportMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="@string/sample_report_meta"
                android:textAppearance="@style/TextAppearance.CivicHero.ReportMeta" />

            <!--
                Chip secundario (apoyos o puntos ganados).
                Visible condicionalmente desde el Adapter:
                  • Estado EN_PROCESO  → muestra apoyos (thumbs up + count)
                  • Estado RESUELTO   → muestra "+X pts ganados"
            -->
            <LinearLayout
                android:id="@+id/chipSecondary"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/chip_secondary_height"
                android:layout_marginTop="@dimen/space_xs"
                android:background="@drawable/bg_chip_secondary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/chip_padding_h"
                android:paddingEnd="@dimen/chip_padding_h"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgChipIcon"
                    android:layout_width="@dimen/icon_xs"
                    android:layout_height="@dimen/icon_xs"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_thumb_up_outline" />

                <TextView
                    android:id="@+id/tvChipLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_xs"
                    android:textAppearance="@style/TextAppearance.CivicHero.ChipLabel" />

            </LinearLayout>

        </LinearLayout>

        <!-- Badge de estado (EN PROCESO / RESUELTO) -->
        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_sm"
            android:gravity="center"
            android:paddingStart="@dimen/badge_padding_h"
            android:paddingTop="@dimen/badge_padding_v"
            android:paddingEnd="@dimen/badge_padding_h"
            android:paddingBottom="@dimen/badge_padding_v"
            android:textAppearance="@style/TextAppearance.CivicHero.StatusBadge" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
