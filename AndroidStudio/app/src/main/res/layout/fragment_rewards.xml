<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    tools:context=".ui.rewards.RewardsActivity">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ===================== HEADER ===================== -->
                <com.google.android.material.appbar.AppBarLayout
                    android:id="@+id/appBarLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_screen"
                    app:elevation="0dp">

                    <include layout="@layout/include_home_topbar" />

                </com.google.android.material.appbar.AppBarLayout>

                <!-- ===================== CONTENIDO ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp">

                    <!-- ==== CARD TU IMPACTO ==== -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_impacto_card"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TU IMPACTO"
                            android:textSize="12sp"
                            android:textColor="#C7D7FB"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvPuntosTotales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="12,450 pts"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <ProgressBar
                            android:id="@+id/progressNivel"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="16dp"
                            android:max="100"
                            android:progress="60"
                            android:progressDrawable="@drawable/progress_impacto" />

                        <TextView
                            android:id="@+id/tvPuntosParaSiguienteNivel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text=""
                            android:textSize="12.5sp"
                            android:textColor="#DCE6FD" />

                    </LinearLayout>

                    <!-- ==== ESTADO DE CARGA / ERROR (compartido) ==== -->
                    <LinearLayout
                        android:id="@+id/layoutEstadoCarga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone"
                        android:paddingVertical="24dp">

                        <ProgressBar
                            android:id="@+id/progressCargaGeneral"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvMensajeError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="#B91C1C"
                            android:textSize="13sp"
                            android:visibility="gone"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- ==== MIS INSIGNIAS ==== -->


                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvInsignias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal" />

                    <!-- ==== CANJEAR PUNTOS ==== -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="Canjear Puntos"
                        android:textSize="16.5sp"
                        android:textStyle="bold"
                        android:textColor="#1A1F2B" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCupones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                    <!-- ==== RANKING PÚBLICO ==== -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Ranking Público"
                        android:textSize="16.5sp"
                        android:textStyle="bold"
                        android:textColor="#1A1F2B" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_white"
                        android:elevation="2dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvRanking"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ===================== BOTTOM NAVIGATION FOOTER ===================== -->


    <!-- ===================== SWIPE REFRESH OVERLAY (opcional) ===================== -->

</androidx.coordinatorlayout.widget.CoordinatorLayout>
