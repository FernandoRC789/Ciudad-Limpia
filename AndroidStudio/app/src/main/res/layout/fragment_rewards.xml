<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    tools:context=".ui.rewards.RewardsActivity">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ===================== HEADER ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_avatar_placeholder" />

                        <ImageView
                            android:id="@+id/imgUserAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tvUserLevelBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="-4dp"
                            android:background="@drawable/bg_pill_level"
                            android:paddingHorizontal="4dp"
                            android:text="LVL 8"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:textColor="#1A1F2B" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="CivicHero"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#1D4ED8" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_bell"
                        android:contentDescription="@null" />

                </LinearLayout>

                <!-- ===================== CONTENIDO ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp">

                    <!-- ==== CARD TU IMPACTO ==== -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_impacto_card"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TU IMPACTO"
                            android:textSize="12sp"
                            android:textColor="#C7D7FB"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvPuntosTotales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="12,450 pts"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <ProgressBar
                            android:id="@+id/progressNivel"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="16dp"
                            android:max="100"
                            android:progress="60"
                            android:progressDrawable="@drawable/progress_impacto" />

                        <TextView
                            android:id="@+id/tvPuntosParaSiguienteNivel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="950 pts para Nivel 9"
                            android:textSize="12.5sp"
                            android:textColor="#DCE6FD" />

                    </LinearLayout>

                    <!-- ==== ESTADO DE CARGA / ERROR (compartido) ==== -->
                    <LinearLayout
                        android:id="@+id/layoutEstadoCarga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone"
                        android:paddingVertical="24dp">

                        <ProgressBar
                            android:id="@+id/progressCargaGeneral"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvMensajeError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="#B91C1C"
                            android:textSize="13sp"
                            android:visibility="gone"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- ==== MIS INSIGNIAS ==== -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="22dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mis Insignias"
                            android:textSize="16.5sp"
                            android:textStyle="bold"
                            android:textColor="#1A1F2B" />

                        <TextView
                            android:id="@+id/tvVerTodasInsignias"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VER TODAS"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1D4ED8"
                            android:padding="4dp" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvInsignias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal" />

                    <!-- ==== CANJEAR PUNTOS ==== -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:text="Canjear Puntos"
                        android:textSize="16.5sp"
                        android:textStyle="bold"
                        android:textColor="#1A1F2B" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCupones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />

                    <!-- ==== RANKING PÚBLICO ==== -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Ranking Público"
                        android:textSize="16.5sp"
                        android:textStyle="bold"
                        android:textColor="#1A1F2B" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_white"
                        android:elevation="2dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvRanking"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPosicionUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="8dp"
                        android:gravity="center"
                        android:text="Estás en la posición #12 de tu distrito"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ===================== BOTTOM NAVIGATION ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Home"
                android:textSize="10.5sp"
                android:textColor="#8A93A3" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReport"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_add_circle"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Report"
                android:textSize="10.5sp"
                android:textColor="#8A93A3" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRewards"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_nav_rewards_active" />

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_trophy_white"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rewards"
                android:textSize="10.5sp"
                android:textStyle="bold"
                android:textColor="#1D4ED8" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Profile"
                android:textSize="10.5sp"
                android:textColor="#8A93A3" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===================== SWIPE REFRESH OVERLAY (opcional) ===================== -->

</androidx.coordinatorlayout.widget.CoordinatorLayout>
