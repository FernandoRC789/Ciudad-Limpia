<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_white"
    android:elevation="2dp"
    android:padding="14dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp">

        <View
            android:id="@+id/viewCuponIconBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_square_lilac" />

        <ImageView
            android:id="@+id/imgCuponIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_trophy"
            android:contentDescription="@null" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCuponNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10% Descuento Impuesto Predial"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:textColor="#1A1F2B"
            android:maxLines="2" />

        <TextView
            android:id="@+id/tvCuponDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Válido para el periodo 2026"
            android:textSize="12.5sp"
            android:textColor="#6B7280"
            android:maxLines="2" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_thumb_up_outline"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tvCuponCosto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="5,000 pts"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="#B8821A" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
